generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  email    String @unique
  password String
}


model SignedForm {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  studentName    String
  formattedText  String
  signature      String
  createdAt      DateTime @default(now())
}


model SignedPdf {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  fileName     String
  studentName  String
  studentData  String
  subjectsData String
  createdAt    DateTime @default(now())
}